<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw-frontier.signed-bus-listener</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/opt/openclaw-frontier-stack/src/signed-bus/examples/listener.js</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/opt/openclaw-frontier-stack</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>NODE_ENV</key>
    <string>production</string>
    <key>OPENCLAW_FRONTIER_ENV_FILE</key>
    <string>/etc/orchestrator-frontier/signed-bus.env</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/var/log/orchestrator-frontier/signed-bus-listener.out.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/orchestrator-frontier/signed-bus-listener.err.log</string>
</dict>
</plist>
