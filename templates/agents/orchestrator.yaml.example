id: orchestrator
role: orchestrator
model: example/provider-model
workspace: ./workspace/demo
permissions:
  tools:
    - read
    - write_demo_artifact
    - bus_send
    - blackboard_claim
    - memory_search
responsibilities:
  - receive user request
  - create and maintain goal cards
  - delegate to role agents
  - enforce result contracts
  - track operator update cadence
  - synthesize traceable outcomes
privacy:
  live_memory: false
  synthetic_demo_data_only: true
