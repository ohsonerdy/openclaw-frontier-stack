{
  "schema": "openclaw-frontier.specialist-registry.v1",
  "specialists": [
    {
      "id": "coding-agent",
      "class": "coding",
      "runtime": "cli-or-subagent",
      "bestFor": ["implementation", "tests", "refactors", "package work"],
      "requires": ["repo path", "acceptance criteria", "allowed files"],
      "returns": ["changed paths", "commit hash or patch", "test output", "blockers"]
    },
    {
      "id": "security-reviewer",
      "class": "security",
      "runtime": "subagent-or-dedicated-agent",
      "bestFor": ["config hardening", "auth review", "exposure checks", "release red-team"],
      "requires": ["scope", "threat model", "rollback plan for mutations"],
      "returns": ["findings", "risk rating", "recommended fix", "verification command"]
    },
    {
      "id": "research-agent",
      "class": "research",
      "runtime": "web-research-agent",
      "bestFor": ["source-backed summaries", "competitive research", "technical discovery"],
      "requires": ["question", "source constraints", "freshness needs"],
      "returns": ["answer", "citations", "confidence", "open questions"]
    },
    {
      "id": "commerce-local-agent",
      "class": "commerce-local",
      "runtime": "local-agent",
      "bestFor": ["collection inventory", "listing prep", "simple local workflows"],
      "requires": ["bounded item set", "privacy constraints", "approval for external posts"],
      "returns": ["artifact paths", "summary", "items needing approval"]
    }
  ]
}
