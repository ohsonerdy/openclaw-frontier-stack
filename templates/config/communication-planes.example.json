{
  "schema": "openclaw-frontier.communication-planes.v1",
  "primary_provider": "telegram|discord|slack",
  "providers": {
    "telegram": {
      "enabled": false,
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "operator_channel_ref": "telegram-operator-placeholder",
      "topics": {
        "operator": "operator-topic-placeholder",
        "squad_status": "status-topic-placeholder",
        "reviews": "reviews-topic-placeholder",
        "alerts": "alerts-topic-placeholder",
        "bot_noise": "bot-noise-topic-placeholder"
      },
      "mention_gate": true
    },
    "discord": {
      "enabled": false,
      "bot_token_env": "DISCORD_BOT_TOKEN",
      "guild_ref": "discord-guild-placeholder",
      "channels": {
        "operator": "operator-channel-placeholder",
        "squad_status": "status-channel-placeholder",
        "reviews": "reviews-channel-placeholder",
        "alerts": "alerts-channel-placeholder",
        "bot_noise": "bot-noise-channel-placeholder"
      },
      "mention_gate": true
    },
    "slack": {
      "enabled": false,
      "bot_token_env": "SLACK_BOT_TOKEN",
      "workspace_ref": "slack-workspace-placeholder",
      "channels": {
        "operator": "operator-channel-placeholder",
        "squad_status": "status-channel-placeholder",
        "reviews": "reviews-channel-placeholder",
        "alerts": "alerts-channel-placeholder",
        "bot_noise": "bot-noise-channel-placeholder"
      },
      "mention_gate": true
    }
  },
  "human_message_policy": {
    "summarize_alerts": true,
    "never_echo_raw_bus_json": true,
    "approval_required_for": [
      "destructive-change",
      "external-publish",
      "credential-handling",
      "privacy-sensitive-action",
      "security-policy-change",
      "cost-impacting-action"
    ]
  }
}
