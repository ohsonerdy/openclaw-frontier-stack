#!/usr/bin/env node
'use strict';

/**
 * openclaw — the OpenClaw Frontier Stack engineer CLI.
 *
 * Subcommands:
 *
 *   openclaw goal "<goal description>"          create a goal from a prompt and run the harness
 *   openclaw goal --file <path>                 read a structured goal record and run the harness
 *   openclaw status                             summarize the blackboard ledger
 *   openclaw dispatch <role> "<task summary>"   write a single task-claim to a role
 *   openclaw recap [--days N]                   roll up the last N days of activity (default 1)
 *   openclaw --help                             show this message
 *
 * Global flags:
 *
 *   --blackboard <path>    Override blackboard ledger path
 *   --mock-agents          (goal) synthesize agent responses in-process
 *   --dry-run              (goal) do not write to the ledger
 *   --max-wait-ms <ms>     (goal) wait budget for live agents
 *   --json                 emit machine-readable JSON instead of pretty text
 *   --days N               (recap) days of history to include (default 1)
 *   --trace-dir <path>     (goal) write the trace JSON to this directory
 *                          (default: release-gate/orchestration/<goalId>/)
 *
 * The CLI works out-of-the-box with no setup. The default `goal` command in
 * mock-agents mode produces a full synthesis trace immediately without a
 * live agent, NATS bus, or any external service running.
 */

const fs = require('fs');
const path = require('path');

const repoRoot = path.resolve(__dirname, '..');
const {
  runGoalLoop,
  goalFromPrompt,
  normalizeGoal,
  blackboardSummary,
  recapBlackboard,
  GoalValidationError,
  toSimpleAgentId,
  toSimpleTaskId,
} = require(path.join(repoRoot, 'src', 'orchestrator', 'lib', 'goal-loop.js'));
const { createLedger, BlackboardValidationError } = require(path.join(repoRoot, 'src', 'blackboard', 'lib', 'ledger.js'));

const HELP_TEXT = `openclaw — OpenClaw Frontier Stack engineer CLI

Usage:
  openclaw goal "<goal description>"          create a goal from a prompt and run the harness
  openclaw goal --file <path>                 read a structured goal record and run the harness
  openclaw goal "<...>" --pattern <name>      use a coordination pattern for the goal
                                              (fan-out|fan-in|chain|voting)
  openclaw status                             summarize the blackboard ledger
  openclaw dispatch <role> "<task summary>"   write a single task-claim to a role
  openclaw recap [--days N]                   roll up the last N days of activity (default 1)
  openclaw watch [--filter K] [--agent A]     tail the blackboard ledger in real time
  openclaw --help                             show this message

Global flags:
  --blackboard <path>    Override blackboard ledger path (default ./blackboard.jsonl)
  --mock-agents          (goal) synthesize agent responses in-process. Default for the
                         CLI prompt path so the harness produces a complete trace
                         without a live agent attached.
  --no-mock-agents       (goal) require live agents
  --dry-run              (goal) do not write to the ledger
  --max-wait-ms <ms>     (goal) wait budget for live agents (default 300000)
  --pattern <name>       (goal) use a coordination pattern (fan-out|fan-in|chain|voting)
  --json                 emit JSON instead of human-readable text
  --days N               (recap) days of history to include (default 1)
  --trace-dir <path>     (goal) when set, also persist the full trace JSON
                         to <path>/trace.json (default: not persisted)

Watch flags:
  --filter <kind>        (watch) only show records of this kind (task-claim,
                         path-claim, path-release, fact, decision, result)
  --agent <name>         (watch) only show records emitted by this agent
  --since <when>         (watch) skip records older than <when> (ISO timestamp
                         or relative: 5m, 1h, 30s)
  --no-color             (watch) disable ANSI color in the output

Exit codes:
  0  Subcommand succeeded
  1  Goal had at least one non-GREEN lane / runtime error
  2  Bad arguments
`;

function help() {
  process.stdout.write(HELP_TEXT);
}

function parseGlobal(argv) {
  const flags = {
    blackboard: path.resolve(process.cwd(), 'blackboard.jsonl'),
    mockAgents: null,
    dryRun: false,
    maxWaitMs: 300000,
    json: false,
    days: 1,
    file: null,
    traceDir: null,
    pattern: null,
    // watch flags
    filter: null,
    agent: null,
    since: null,
    color: true,
  };
  const positional = [];
  for (let i = 2; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === '--blackboard') flags.blackboard = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--mock-agents') flags.mockAgents = true;
    else if (a === '--no-mock-agents') flags.mockAgents = false;
    else if (a === '--dry-run') flags.dryRun = true;
    else if (a === '--max-wait-ms') flags.maxWaitMs = Number(argv[++i]);
    else if (a === '--json') flags.json = true;
    else if (a === '--days') flags.days = Math.max(1, Number(argv[++i]) || 1);
    else if (a === '--file' || a === '-f') flags.file = argv[++i];
    else if (a === '--trace-dir') flags.traceDir = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--pattern') flags.pattern = argv[++i];
    else if (a === '--filter') flags.filter = argv[++i];
    else if (a === '--agent') flags.agent = argv[++i];
    else if (a === '--since') flags.since = argv[++i];
    else if (a === '--no-color') flags.color = false;
    else if (a === '--help' || a === '-h') flags.help = true;
    else positional.push(a);
  }
  return { flags, positional };
}

function emit(value, json) {
  if (json) {
    process.stdout.write(JSON.stringify(value, null, 2) + '\n');
    return;
  }
  if (typeof value === 'string') {
    process.stdout.write(value.endsWith('\n') ? value : value + '\n');
    return;
  }
  process.stdout.write(JSON.stringify(value, null, 2) + '\n');
}

function writeTrace(trace, traceDir) {
  if (!trace || !trace.goalId) return null;
  const dir = traceDir || path.join(repoRoot, 'release-gate', 'orchestration', trace.goalId);
  fs.mkdirSync(dir, { recursive: true });
  const tracePath = path.join(dir, 'trace.json');
  fs.writeFileSync(tracePath, JSON.stringify(trace, null, 2) + '\n');
  return tracePath;
}

function renderTraceText(trace) {
  const lines = [];
  lines.push(`goal: ${trace.goalId}`);
  lines.push(`title: ${trace.title}`);
  lines.push(`ok: ${trace.ok ? 'YES (all lanes green)' : 'NO'}`);
  lines.push(`mockAgents: ${trace.mockAgents ? 'true' : 'false'}`);
  if (trace.dryRun) lines.push('mode: dry-run');
  lines.push('lanes:');
  for (const lane of trace.lanes || []) {
    const tag = lane.pattern ? ` pattern=${lane.pattern}` : '';
    lines.push(`  - ${lane.name} (${lane.role})${tag} [${lane.status}] ${lane.summary}`);
  }
  if (trace.green && trace.green.length) lines.push(`green: ${trace.green.join(', ')}`);
  if (trace.red && trace.red.length) lines.push(`red: ${trace.red.join(', ')}`);
  return lines.join('\n');
}

function renderStatusText(summary) {
  const lines = [];
  lines.push(`blackboard: ${summary.ledgerPath}`);
  lines.push(`exists: ${summary.exists}`);
  lines.push(`total records: ${summary.totalRecords}`);
  const counts = summary.counts || {};
  const countLine = Object.keys(counts).sort().map((k) => `${k}=${counts[k]}`).join(' ');
  lines.push(`record counts: ${countLine || '(none)'}`);
  lines.push(`active tasks: ${summary.tasks.active.length}`);
  for (const t of summary.tasks.active.slice(0, 5)) {
    lines.push(`  - ${t.taskId} owned-by ${t.agent} :: ${t.summary}`);
  }
  lines.push(`completed tasks: ${summary.tasks.done.length}`);
  lines.push(`failed tasks: ${summary.tasks.failed.length}`);
  lines.push(`path claims: ${summary.pathClaims.length}`);
  lines.push(`recent results:`);
  for (const r of (summary.recentResults || []).slice(0, 5)) {
    lines.push(`  - ${r.ts} ${r.agent} -> ${r.taskId} ok=${r.ok} ${r.summary.slice(0, 80)}`);
  }
  return lines.join('\n');
}

function renderRecapText(recap) {
  const lines = [];
  lines.push(`blackboard: ${recap.ledgerPath}`);
  lines.push(`window: ${recap.sinceISO} → ${recap.untilISO || 'now'}`);
  for (const line of recap.narrative || []) lines.push(line);
  return lines.join('\n');
}

async function cmdGoal(positional, flags) {
  let goal;
  if (flags.file) {
    const resolved = path.resolve(process.cwd(), flags.file);
    if (!fs.existsSync(resolved)) {
      process.stderr.write(`goal file not found: ${resolved}\n`);
      process.exit(2);
    }
    try {
      goal = normalizeGoal(JSON.parse(fs.readFileSync(resolved, 'utf8')));
    } catch (err) {
      process.stderr.write(`goal file invalid: ${err.message}\n`);
      process.exit(2);
    }
  } else {
    const prompt = positional.slice(1).join(' ').trim();
    if (!prompt) {
      process.stderr.write('openclaw goal: provide a description (in quotes) or --file <path>\n');
      process.exit(2);
    }
    try {
      goal = goalFromPrompt(prompt, { pattern: flags.pattern });
    } catch (err) {
      process.stderr.write(`goal prompt invalid: ${err.message}\n`);
      process.exit(2);
    }
  }
  // CLI default: mock-agents=true unless explicitly disabled. This makes
  // the no-setup path work without a live bus.
  const mockAgents = flags.mockAgents === null ? true : flags.mockAgents;
  let trace;
  try {
    trace = await runGoalLoop({
      goal,
      blackboardPath: flags.blackboard,
      maxWaitMs: flags.maxWaitMs,
      mockAgents,
      dryRun: flags.dryRun,
    });
  } catch (err) {
    if (err instanceof GoalValidationError) {
      process.stderr.write(`goal invalid: ${err.message}\n`);
      process.exit(2);
    }
    if (err instanceof BlackboardValidationError) {
      process.stderr.write(`blackboard error: ${err.message}\n`);
      process.exit(1);
    }
    process.stderr.write(`runtime error: ${err.stack || err.message || err}\n`);
    process.exit(1);
  }
  // Only persist the trace when an explicit --trace-dir was provided. The
  // stdout emission is the canonical sink for the CLI; piping a trace into
  // a file is the caller's call.
  const tracePath = (!flags.dryRun && flags.traceDir) ? writeTrace(trace, flags.traceDir) : null;
  if (tracePath) trace.tracePath = path.relative(process.cwd(), tracePath);
  if (flags.json) emit(trace, true);
  else emit(renderTraceText(trace));
  if (flags.dryRun) return;
  process.exit(trace.ok ? 0 : 1);
}

function cmdStatus(_positional, flags) {
  const summary = blackboardSummary(flags.blackboard);
  if (flags.json) emit(summary, true);
  else emit(renderStatusText(summary));
}

function cmdDispatch(positional, flags) {
  const role = positional[1];
  const description = positional.slice(2).join(' ').trim();
  if (!role || !description) {
    process.stderr.write('openclaw dispatch: usage: openclaw dispatch <role> "<task description>"\n');
    process.exit(2);
  }
  let agent;
  try {
    agent = toSimpleAgentId(role, 'role');
  } catch (err) {
    process.stderr.write(`role invalid: ${err.message}\n`);
    process.exit(2);
  }
  let taskId;
  try {
    taskId = `dispatch-${toSimpleTaskId(description.slice(0, 40), 'task id')}-${Date.now().toString(36)}`;
  } catch (err) {
    process.stderr.write(`task description cannot be reduced to a task id: ${err.message}\n`);
    process.exit(2);
  }
  if (flags.dryRun) {
    const preview = {
      schema: 'openclaw-frontier.dispatch-preview.v1',
      dryRun: true,
      agent,
      taskId,
      summary: description.slice(0, 500),
    };
    if (flags.json) emit(preview, true);
    else emit(`would dispatch:\n  taskId: ${taskId}\n  agent: ${agent}\n  summary: ${preview.summary}`);
    return;
  }
  const ledger = createLedger({ ledgerPath: flags.blackboard });
  let record;
  try {
    record = ledger.claimTask({
      agent: 'orchestrator',
      taskId,
      summary: description.slice(0, 500),
    });
  } catch (err) {
    process.stderr.write(`dispatch failed: ${err.message}\n`);
    process.exit(1);
  }
  const result = {
    schema: 'openclaw-frontier.dispatch-receipt.v1',
    ok: true,
    agent,
    taskId,
    claimId: record.id,
    claimedAt: record.ts,
    blackboard: flags.blackboard,
    note: 'task-claim written. agent will pick the task off the ledger and respond with a result record.',
  };
  if (flags.json) emit(result, true);
  else emit(`dispatched ${taskId}\n  claim: ${record.id}\n  agent: ${agent}\n  blackboard: ${flags.blackboard}`);
}

function cmdRecap(_positional, flags) {
  const recap = recapBlackboard(flags.blackboard, { days: flags.days });
  if (flags.json) emit(recap, true);
  else emit(renderRecapText(recap));
}

// ---------- openclaw watch ----------

const ANSI = {
  reset: '\x1b[0m',
  dim: '\x1b[2m',
  bold: '\x1b[1m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  cyan: '\x1b[36m',
};

const KIND_COLOR = {
  'task-claim': 'cyan',
  'path-claim': 'yellow',
  'path-release': 'dim',
  'fact': 'blue',
  'decision': 'magenta',
  'result': 'green', // green for ok, red for not-ok (handled below)
};

function parseSince(raw) {
  if (!raw) return null;
  const s = String(raw).trim();
  if (!s) return null;
  // Relative form: 5m, 1h, 30s, 2d
  const rel = /^(\d+)\s*([smhd])$/i.exec(s);
  if (rel) {
    const n = Number(rel[1]);
    const unit = rel[2].toLowerCase();
    const factor = unit === 's' ? 1000 : unit === 'm' ? 60000 : unit === 'h' ? 3600000 : 86400000;
    return Date.now() - n * factor;
  }
  // ISO form
  const parsed = Date.parse(s);
  if (!Number.isFinite(parsed)) throw new Error(`--since: cannot parse "${raw}" (use ISO timestamp or 5m/1h/30s/2d)`);
  return parsed;
}

function formatTime(ts) {
  const d = new Date(ts);
  if (Number.isNaN(d.getTime())) return '??:??:??';
  return d.toISOString().slice(11, 19); // HH:MM:SS
}

function colorize(text, color, useColor) {
  if (!useColor || !color || !ANSI[color]) return text;
  return `${ANSI[color]}${text}${ANSI.reset}`;
}

function padRight(s, w) {
  s = String(s);
  if (s.length >= w) return s;
  return s + ' '.repeat(w - s.length);
}

function truncate(s, max) {
  s = String(s);
  if (s.length <= max) return s;
  return s.slice(0, max - 1) + '…';
}

function formatRecord(record, useColor) {
  const time = colorize(formatTime(record.ts), 'dim', useColor);
  const kindLabel = padRight(record.kind, 12);
  let color = KIND_COLOR[record.kind] || null;
  if (record.kind === 'result' && record.ok === false) color = 'red';
  const kind = colorize(kindLabel, color, useColor);
  const agent = colorize(padRight((record.agent || '-').slice(0, 12), 12), 'bold', useColor);
  const taskId = padRight((record.taskId || '-').slice(0, 24), 24);
  let detail = '';
  if (record.kind === 'task-claim') {
    detail = `"${truncate(record.summary || '', 60)}"`;
  } else if (record.kind === 'path-claim') {
    detail = `${record.path} (${record.mode || 'write'})`;
  } else if (record.kind === 'path-release') {
    detail = `${record.path}`;
  } else if (record.kind === 'fact') {
    detail = `${record.subject}`;
  } else if (record.kind === 'decision') {
    detail = `${record.decision} (${record.status || 'accepted'})`;
  } else if (record.kind === 'result') {
    const verdict = record.ok ? 'ok' : 'FAIL';
    const verdictColored = colorize(verdict, record.ok ? 'green' : 'red', useColor);
    const arts = record.artifacts && record.artifacts.length ? ` (artifact: ${record.artifacts[0]}${record.artifacts.length > 1 ? ` +${record.artifacts.length - 1}` : ''})` : '';
    detail = `${verdictColored} ${truncate(record.summary || '', 50)}${arts}`;
  }
  return `${time}  ${kind}  ${agent}  ${taskId}  ${detail}`;
}

function recordMatchesFilter(record, flags, sinceMs) {
  if (flags.filter && record.kind !== flags.filter) return false;
  if (flags.agent && record.agent !== flags.agent) return false;
  if (sinceMs != null) {
    const ts = Date.parse(record.ts);
    if (Number.isFinite(ts) && ts < sinceMs) return false;
  }
  return true;
}

function parseJsonlLines(text) {
  const out = [];
  const lines = text.split(/\r?\n/);
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    try {
      out.push(JSON.parse(trimmed));
    } catch (err) {
      // Skip malformed lines silently — the watcher should never block on bad
      // input the rest of the pipeline already validates.
    }
  }
  return out;
}

async function cmdWatch(_positional, flags) {
  const useColor = flags.color && process.stdout.isTTY !== false;
  let sinceMs;
  try {
    sinceMs = parseSince(flags.since);
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(2);
  }
  const blackboardPath = flags.blackboard;

  // Print a small banner so the operator knows we're tailing.
  if (!flags.json) {
    process.stdout.write(`# openclaw watch: tailing ${blackboardPath}` +
      (flags.filter ? ` filter=${flags.filter}` : '') +
      (flags.agent ? ` agent=${flags.agent}` : '') +
      (flags.since ? ` since=${flags.since}` : '') +
      '\n');
  }

  // Tracking state. We poll the file size + emit any new bytes' worth of
  // records since the last position. This is the cheapest cross-platform
  // strategy and avoids fs.watch quirks on Windows.
  let lastSize = 0;
  let bufRemainder = '';
  let printedAny = false;
  let waitedFile = false;

  const printOne = (record) => {
    if (!recordMatchesFilter(record, flags, sinceMs)) return;
    if (flags.json) {
      process.stdout.write(JSON.stringify(record) + '\n');
    } else {
      process.stdout.write(formatRecord(record, useColor) + '\n');
    }
    printedAny = true;
  };

  // Initial pass: replay the current file (subject to --since), then keep
  // tailing.
  if (fs.existsSync(blackboardPath)) {
    const initial = fs.readFileSync(blackboardPath, 'utf8');
    lastSize = Buffer.byteLength(initial, 'utf8');
    for (const record of parseJsonlLines(initial)) printOne(record);
    if (!flags.json && !printedAny) process.stdout.write(`# (no matching records yet — waiting for activity)\n`);
  } else if (!flags.json) {
    process.stdout.write(`# (blackboard file not present yet — waiting)\n`);
    waitedFile = true;
  }

  // SIGINT: exit gracefully.
  let shuttingDown = false;
  process.on('SIGINT', () => {
    if (shuttingDown) process.exit(130);
    shuttingDown = true;
    if (!flags.json) process.stdout.write('\n# watch: interrupted\n');
    process.exit(0);
  });

  // Tail loop. Poll every 500ms; read only the new tail bytes since lastSize.
  // We do not use fs.watch because (a) it's unreliable on some Windows fs
  // backends and (b) we need ordered reads of append-only JSONL anyway.
  while (true) {
    let stat;
    try { stat = fs.statSync(blackboardPath); } catch (_) { stat = null; }
    if (!stat) {
      await sleep(500);
      continue;
    }
    if (waitedFile && stat.size > 0 && !flags.json) {
      process.stdout.write(`# (blackboard file appeared — tailing)\n`);
      waitedFile = false;
    }
    if (stat.size < lastSize) {
      // File got truncated/rotated. Re-seed from start.
      lastSize = 0;
      bufRemainder = '';
    }
    if (stat.size > lastSize) {
      const fd = fs.openSync(blackboardPath, 'r');
      try {
        const length = stat.size - lastSize;
        const buf = Buffer.alloc(length);
        fs.readSync(fd, buf, 0, length, lastSize);
        lastSize = stat.size;
        const text = bufRemainder + buf.toString('utf8');
        // Hold back any trailing partial line until we see the next newline.
        const lastNewline = text.lastIndexOf('\n');
        let complete;
        if (lastNewline === -1) {
          complete = '';
          bufRemainder = text;
        } else {
          complete = text.slice(0, lastNewline + 1);
          bufRemainder = text.slice(lastNewline + 1);
        }
        for (const record of parseJsonlLines(complete)) printOne(record);
      } finally {
        fs.closeSync(fd);
      }
    }
    await sleep(500);
  }
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function main() {
  if (process.argv.length <= 2) { help(); process.exit(2); }
  const { flags, positional } = parseGlobal(process.argv);
  if (flags.help || positional[0] === 'help') { help(); return; }
  const sub = positional[0];
  switch (sub) {
    case 'goal': return cmdGoal(positional, flags);
    case 'status': return cmdStatus(positional, flags);
    case 'dispatch': return cmdDispatch(positional, flags);
    case 'recap': return cmdRecap(positional, flags);
    case 'watch': return cmdWatch(positional, flags);
    case undefined: help(); process.exit(2); return;
    default:
      process.stderr.write(`unknown subcommand: ${sub}\n`);
      help();
      process.exit(2);
  }
}

main().catch((err) => {
  process.stderr.write(`openclaw: ${err.stack || err.message || err}\n`);
  process.exit(1);
});
