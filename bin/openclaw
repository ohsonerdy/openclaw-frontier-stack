#!/usr/bin/env node
'use strict';

/**
 * openclaw — the OpenClaw Frontier Stack engineer CLI.
 *
 * Subcommands:
 *
 *   openclaw goal "<goal description>"          create a goal from a prompt and run the harness
 *   openclaw goal --file <path>                 read a structured goal record and run the harness
 *   openclaw status                             summarize the blackboard ledger
 *   openclaw dispatch <role> "<task summary>"   write a single task-claim to a role
 *   openclaw recap [--days N]                   roll up the last N days of activity (default 1)
 *   openclaw --help                             show this message
 *
 * Global flags:
 *
 *   --blackboard <path>    Override blackboard ledger path
 *   --mock-agents          (goal) synthesize agent responses in-process
 *   --dry-run              (goal) do not write to the ledger
 *   --max-wait-ms <ms>     (goal) wait budget for live agents
 *   --json                 emit machine-readable JSON instead of pretty text
 *   --days N               (recap) days of history to include (default 1)
 *   --trace-dir <path>     (goal) write the trace JSON to this directory
 *                          (default: release-gate/orchestration/<goalId>/)
 *
 * The CLI works out-of-the-box with no setup. The default `goal` command in
 * mock-agents mode produces a full synthesis trace immediately without a
 * live agent, NATS bus, or any external service running.
 */

const fs = require('fs');
const path = require('path');

const repoRoot = path.resolve(__dirname, '..');
const {
  runGoalLoop,
  goalFromPrompt,
  normalizeGoal,
  blackboardSummary,
  recapBlackboard,
  GoalValidationError,
  toSimpleAgentId,
  toSimpleTaskId,
  goalState,
} = require(path.join(repoRoot, 'src', 'orchestrator', 'lib', 'goal-loop.js'));
const { createLedger, BlackboardValidationError } = require(path.join(repoRoot, 'src', 'blackboard', 'lib', 'ledger.js'));
const {
  createTicketStore,
  TicketStateError,
  TicketValidationError,
  STATES: TICKET_STATES,
} = require(path.join(repoRoot, 'src', 'tickets', 'lib', 'ticket-store.js'));
const goalTemplates = require(path.join(repoRoot, 'lib', 'goal-templates', 'index.js'));

const HELP_TEXT = `openclaw — OpenClaw Frontier Stack engineer CLI

Usage:
  openclaw goal "<goal description>"          create a goal from a prompt and run the harness
  openclaw goal --file <path>                 read a structured goal record and run the harness
  openclaw goal "<...>" --pattern <name>      use a coordination pattern for the goal
                                              (fan-out|fan-in|chain|voting)
  openclaw goal --template <name> "<ctx>"     instantiate a named goal template
                                              (see openclaw goal --list-templates)
  openclaw goal --list-templates              show available goal templates
  openclaw goal --list [--all]                show recent persisted goal states
  openclaw goal --show <goal_id>              print the state summary for a goal
  openclaw goal --resume <goal_id>            re-attach to a persisted goal and finish it
  openclaw status                             summarize the blackboard ledger
  openclaw dispatch <role> "<task summary>"   write a single task-claim to a role
  openclaw recap [--days N] [--cost]          roll up the last N days of activity (default 1)
  openclaw watch [--filter K] [--agent A]     tail the blackboard ledger in real time
  openclaw ticket <action> [args]             ticket FSM (see "openclaw ticket --help")
  openclaw --help                             show this message

Global flags:
  --blackboard <path>    Override blackboard ledger path (default ./blackboard.jsonl)
  --mock-agents          (goal) synthesize agent responses in-process. Default for the
                         CLI prompt path so the harness produces a complete trace
                         without a live agent attached.
  --no-mock-agents       (goal) require live agents
  --dry-run              (goal) do not write to the ledger
  --max-wait-ms <ms>     (goal) wait budget for live agents (default 300000)
  --pattern <name>       (goal) use a coordination pattern (fan-out|fan-in|chain|voting)
  --template <name>      (goal) instantiate a named template (mutex with --file)
  --list-templates       (goal) print available templates and exit
  --list                 (goal) list persisted goals (most recent 20)
  --all                  (goal) with --list, show all goals
  --show <goal_id>       (goal) show the persisted state for a goal id
  --resume <goal_id>     (goal) resume a partial goal
  --no-persist           (goal) do not write a .openclaw/goals/<id>.json state file
  --goals-dir <path>     (goal) override the directory used for persisted state
                         (default: <blackboard-parent>/.openclaw/goals/)
  --quiet                (goal) suppress per-lane progress on stderr
  --verbose              (goal) print extra detail (timestamps, taskIds, byte counts)
  --cost                 (recap) include per-goal USD cost estimates in the recap
  --json                 emit JSON instead of human-readable text
  --days N               (recap) days of history to include (default 1)
  --trace-dir <path>     (goal) when set, also persist the full trace JSON
                         to <path>/trace.json (default: not persisted)

Watch flags:
  --filter <kind>        (watch) only show records of this kind (task-claim,
                         path-claim, path-release, fact, decision, result)
  --agent <name>         (watch) only show records emitted by this agent
  --since <when>         (watch) skip records older than <when> (ISO timestamp
                         or relative: 5m, 1h, 30s)
  --no-color             (watch) disable ANSI color in the output

Exit codes:
  0  Subcommand succeeded
  1  Goal had at least one non-GREEN lane / runtime error
  2  Bad arguments
`;

function help() {
  process.stdout.write(HELP_TEXT);
}

function parseGlobal(argv) {
  const flags = {
    blackboard: path.resolve(process.cwd(), 'blackboard.jsonl'),
    mockAgents: null,
    dryRun: false,
    maxWaitMs: 300000,
    json: false,
    days: 1,
    file: null,
    traceDir: null,
    pattern: null,
    // goal templating + state persistence
    template: null,
    listTemplates: false,
    listGoals: false,
    showGoal: null,
    resumeGoal: null,
    persistState: true,
    goalsDir: null,
    all: false,
    quiet: false,
    verbose: false,
    cost: false,
    // watch flags
    filter: null,
    agent: null,
    since: null,
    color: true,
    // ticket flags
    ticketsPath: null,
    body: null,
    assignedTo: null,
    priority: null,
    dependsOn: null,
    slaHours: null,
    by: null,
    to: null,
    reviewer: null,
    resolution: null,
    reason: null,
    comment: null,
    status: null,
    blocked: false,
  };
  const positional = [];
  for (let i = 2; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === '--blackboard') flags.blackboard = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--mock-agents') flags.mockAgents = true;
    else if (a === '--no-mock-agents') flags.mockAgents = false;
    else if (a === '--dry-run') flags.dryRun = true;
    else if (a === '--max-wait-ms') flags.maxWaitMs = Number(argv[++i]);
    else if (a === '--json') flags.json = true;
    else if (a === '--days') flags.days = Math.max(1, Number(argv[++i]) || 1);
    else if (a === '--file' || a === '-f') flags.file = argv[++i];
    else if (a === '--trace-dir') flags.traceDir = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--pattern') flags.pattern = argv[++i];
    else if (a === '--template') flags.template = argv[++i];
    else if (a === '--list-templates') flags.listTemplates = true;
    else if (a === '--list') flags.listGoals = true;
    else if (a === '--show') flags.showGoal = argv[++i];
    else if (a === '--resume') flags.resumeGoal = argv[++i];
    else if (a === '--no-persist') flags.persistState = false;
    else if (a === '--goals-dir') flags.goalsDir = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--all') flags.all = true;
    else if (a === '--quiet') flags.quiet = true;
    else if (a === '--verbose') flags.verbose = true;
    else if (a === '--cost') flags.cost = true;
    else if (a === '--filter') flags.filter = argv[++i];
    else if (a === '--agent') flags.agent = argv[++i];
    else if (a === '--since') flags.since = argv[++i];
    else if (a === '--no-color') flags.color = false;
    // Ticket-specific flags. The same global parser is used for every
    // subcommand, so each new flag is namespaced by its long name; ticket
    // flags only do something inside cmdTicket.
    else if (a === '--tickets-path') flags.ticketsPath = path.resolve(process.cwd(), argv[++i]);
    else if (a === '--body') flags.body = argv[++i];
    else if (a === '--assigned-to') flags.assignedTo = argv[++i];
    else if (a === '--priority') flags.priority = argv[++i];
    else if (a === '--depends-on') flags.dependsOn = argv[++i];
    else if (a === '--sla-hours') flags.slaHours = Number(argv[++i]);
    else if (a === '--by') flags.by = argv[++i];
    else if (a === '--to') flags.to = argv[++i];
    else if (a === '--reviewer') flags.reviewer = argv[++i];
    else if (a === '--resolution') flags.resolution = argv[++i];
    else if (a === '--reason') flags.reason = argv[++i];
    else if (a === '--comment') flags.comment = argv[++i];
    else if (a === '--status') flags.status = argv[++i];
    else if (a === '--blocked') flags.blocked = true;
    else if (a === '--help' || a === '-h') flags.help = true;
    else positional.push(a);
  }
  return { flags, positional };
}

function emit(value, json) {
  if (json) {
    process.stdout.write(JSON.stringify(value, null, 2) + '\n');
    return;
  }
  if (typeof value === 'string') {
    process.stdout.write(value.endsWith('\n') ? value : value + '\n');
    return;
  }
  process.stdout.write(JSON.stringify(value, null, 2) + '\n');
}

function writeTrace(trace, traceDir) {
  if (!trace || !trace.goalId) return null;
  const dir = traceDir || path.join(repoRoot, 'release-gate', 'orchestration', trace.goalId);
  fs.mkdirSync(dir, { recursive: true });
  const tracePath = path.join(dir, 'trace.json');
  fs.writeFileSync(tracePath, JSON.stringify(trace, null, 2) + '\n');
  return tracePath;
}

function renderTraceText(trace) {
  const lines = [];
  lines.push(`goal: ${trace.goalId}`);
  lines.push(`title: ${trace.title}`);
  lines.push(`ok: ${trace.ok ? 'YES (all lanes green)' : 'NO'}`);
  lines.push(`mockAgents: ${trace.mockAgents ? 'true' : 'false'}`);
  if (trace.dryRun) lines.push('mode: dry-run');
  lines.push('lanes:');
  for (const lane of trace.lanes || []) {
    const tag = lane.pattern ? ` pattern=${lane.pattern}` : '';
    lines.push(`  - ${lane.name} (${lane.role})${tag} [${lane.status}] ${lane.summary}`);
  }
  if (trace.green && trace.green.length) lines.push(`green: ${trace.green.join(', ')}`);
  if (trace.red && trace.red.length) lines.push(`red: ${trace.red.join(', ')}`);
  if (trace.cost && (trace.cost.callCount || trace.cost.usd)) {
    lines.push(`cost: $${(trace.cost.usd || 0).toFixed(6)} (${trace.cost.callCount} model calls)`);
  }
  if (trace.statePath) lines.push(`statePath: ${trace.statePath}`);
  return lines.join('\n');
}

function renderStatusText(summary) {
  const lines = [];
  lines.push(`blackboard: ${summary.ledgerPath}`);
  lines.push(`exists: ${summary.exists}`);
  lines.push(`total records: ${summary.totalRecords}`);
  const counts = summary.counts || {};
  const countLine = Object.keys(counts).sort().map((k) => `${k}=${counts[k]}`).join(' ');
  lines.push(`record counts: ${countLine || '(none)'}`);
  lines.push(`active tasks: ${summary.tasks.active.length}`);
  for (const t of summary.tasks.active.slice(0, 5)) {
    lines.push(`  - ${t.taskId} owned-by ${t.agent} :: ${t.summary}`);
  }
  lines.push(`completed tasks: ${summary.tasks.done.length}`);
  lines.push(`failed tasks: ${summary.tasks.failed.length}`);
  lines.push(`path claims: ${summary.pathClaims.length}`);
  lines.push(`recent results:`);
  for (const r of (summary.recentResults || []).slice(0, 5)) {
    lines.push(`  - ${r.ts} ${r.agent} -> ${r.taskId} ok=${r.ok} ${r.summary.slice(0, 80)}`);
  }
  return lines.join('\n');
}

function renderRecapText(recap) {
  const lines = [];
  lines.push(`blackboard: ${recap.ledgerPath}`);
  lines.push(`window: ${recap.sinceISO} → ${recap.untilISO || 'now'}`);
  for (const line of recap.narrative || []) lines.push(line);
  return lines.join('\n');
}

function buildProgressEmitter(flags) {
  if (flags.quiet) return null;
  const verbose = Boolean(flags.verbose);
  return function progress(event) {
    if (!event || !event.kind) return;
    const ts = verbose ? `${new Date().toISOString().slice(11, 19)} ` : '';
    let line;
    switch (event.kind) {
      case 'goal-start':
        line = `goal-start ${event.goalId}${verbose ? ` lanes=${event.lanes} mockAgents=${event.mockAgents}` : ''}: ${event.title}`;
        break;
      case 'resume-start':
        line = `resume ${event.goalId} (prior status=${event.status})`;
        break;
      case 'resume-noop':
        line = `resume noop: ${event.goalId} already ${event.status}`;
        break;
      case 'lane-dispatched':
        line = `dispatching ${event.laneName}${event.role ? ` (${event.role})` : ''}${verbose ? ` taskId=${event.taskId}` : ''}${event.resumed ? ' [resumed]' : ''}`;
        break;
      case 'pattern-lane-start':
        line = `pattern-lane ${event.pattern} start: ${event.laneName}`;
        break;
      case 'pattern-lane-done':
        line = `pattern-lane done: ${event.laneName} ok=${event.ok}`;
        break;
      case 'pattern-lane-skipped':
        line = `pattern-lane skipped: ${event.laneName} (${event.reason})`;
        break;
      case 'result-received':
        line = `received ${event.laneName} ok=${event.ok}${verbose ? ` agent=${event.agent} taskId=${event.taskId} bytes=${(event.summary || '').length}` : ''}`;
        break;
      case 'lane-retry-dispatch':
        line = `retrying ${event.laneName} (attempt ${event.attempt}/${event.max})${verbose ? ` taskId=${event.taskId}` : ''}`;
        break;
      case 'lane-aborted':
        line = `aborted: lanes=${event.laneNames.join(',')}`;
        break;
      case 'goal-done':
        line = `goal-done ${event.goalId} ok=${event.ok} status=${event.status} cost=$${(event.usd || 0).toFixed(6)} (${event.callCount} model calls)`;
        break;
      default:
        if (!verbose) return;
        line = `event ${event.kind}`;
    }
    process.stderr.write(`${ts}${line}\n`);
  };
}

function renderGoalList(states) {
  const lines = [];
  if (states.length === 0) {
    lines.push('(no persisted goals found)');
    return lines.join('\n');
  }
  lines.push('goalId                                          status     usd        calls  updatedAt              title');
  for (const s of states) {
    const usd = `$${(s.usd || 0).toFixed(6)}`.padStart(11);
    const calls = String(s.callCount || 0).padStart(5);
    const id = String(s.goalId).slice(0, 48).padEnd(48);
    const status = String(s.status || '').padEnd(10);
    const updated = String(s.updatedAt || '').slice(0, 22).padEnd(22);
    lines.push(`${id} ${status} ${usd}  ${calls}  ${updated} ${(s.title || '').slice(0, 70)}`);
  }
  return lines.join('\n');
}

function renderGoalShow(state) {
  const lines = [];
  lines.push(`goal: ${state.goalId}`);
  lines.push(`title: ${state.title}`);
  lines.push(`status: ${state.status}`);
  lines.push(`createdAt: ${state.createdAt}`);
  lines.push(`updatedAt: ${state.updatedAt}`);
  if (state.completedAt) lines.push(`completedAt: ${state.completedAt}`);
  lines.push(`blackboard: ${state.blackboardPath}`);
  if (state.options) {
    lines.push(`options: mockAgents=${state.options.mockAgents} dryRun=${state.options.dryRun} maxWaitMs=${state.options.maxWaitMs}` +
      (state.options.templateName ? ` template=${state.options.templateName}` : ''));
  }
  if (state.goal && Array.isArray(state.goal.lanes)) {
    lines.push(`lanes (${state.goal.lanes.length}):`);
    for (const lane of state.goal.lanes) {
      const tag = lane.pattern ? ` pattern=${lane.pattern}` : '';
      lines.push(`  - ${lane.name}${tag} role=${lane.role || '(orchestrator)'}`);
    }
  }
  if (state.cost) {
    lines.push(`cost estimate: $${(state.cost.usd || 0).toFixed(6)} (${state.cost.callCount} calls)`);
    if (state.cost.usage) {
      lines.push(`  tokens: in=${state.cost.usage.input} out=${state.cost.usage.output} cache_write=${state.cost.usage.cache_write} cache_read=${state.cost.usage.cache_read}`);
    }
    for (const [model, sub] of Object.entries(state.cost.perModel || {})) {
      lines.push(`  ${model}: $${(sub.usd || 0).toFixed(6)} over ${sub.callCount} call${sub.callCount === 1 ? '' : 's'}`);
    }
  }
  if (state.errors && state.errors.length) {
    lines.push('errors:');
    for (const e of state.errors.slice(0, 5)) lines.push(`  - ${e.ts}: ${e.message}`);
  }
  return lines.join('\n');
}

async function cmdGoal(positional, flags) {
  // --list-templates: enumerate available templates and exit.
  if (flags.listTemplates) {
    const list = goalTemplates.listTemplates();
    if (flags.json) emit(list, true);
    else {
      const lines = list.map((t) => `${t.name.padEnd(20)} (${t.laneCount} lanes) :: ${(t.title || '').slice(0, 80)}\n  ${t.description || ''}`);
      emit(lines.join('\n'));
    }
    return;
  }

  // --list: show recent persisted goal states.
  if (flags.listGoals) {
    const dir = goalState.resolveGoalsDir({ blackboardPath: flags.blackboard, override: flags.goalsDir });
    const states = goalState.listStates(dir, { all: Boolean(flags.all), limit: 20 });
    if (flags.json) emit({ goalsDir: dir, states }, true);
    else {
      emit(`goalsDir: ${dir}`);
      emit(renderGoalList(states));
    }
    return;
  }

  // --show <id>: print the state file.
  if (flags.showGoal) {
    const dir = goalState.resolveGoalsDir({ blackboardPath: flags.blackboard, override: flags.goalsDir });
    let state;
    try { state = goalState.readState(dir, flags.showGoal); }
    catch (err) { process.stderr.write(`${err.message}\n`); process.exit(2); }
    if (flags.json) emit(state, true);
    else emit(renderGoalShow(state));
    return;
  }

  // Mutual exclusion: --template and --file cannot be combined.
  if (flags.template && flags.file) {
    process.stderr.write('openclaw goal: --template and --file are mutually exclusive\n');
    process.exit(2);
  }

  // --resume <id>: re-attach.
  const resumeMode = Boolean(flags.resumeGoal);
  let goal = null;
  if (resumeMode) {
    goal = { id: flags.resumeGoal };
  } else if (flags.template) {
    const contextStr = positional.slice(1).join(' ').trim();
    if (!contextStr) {
      process.stderr.write('openclaw goal --template <name> requires a context string (in quotes)\n');
      process.exit(2);
    }
    try {
      goal = goalTemplates.instantiateTemplate(flags.template, contextStr);
    } catch (err) {
      process.stderr.write(`template error: ${err.message}\n`);
      process.exit(2);
    }
  } else if (flags.file) {
    const resolved = path.resolve(process.cwd(), flags.file);
    if (!fs.existsSync(resolved)) {
      process.stderr.write(`goal file not found: ${resolved}\n`);
      process.exit(2);
    }
    try {
      goal = normalizeGoal(JSON.parse(fs.readFileSync(resolved, 'utf8')));
    } catch (err) {
      process.stderr.write(`goal file invalid: ${err.message}\n`);
      process.exit(2);
    }
  } else {
    const prompt = positional.slice(1).join(' ').trim();
    if (!prompt) {
      process.stderr.write('openclaw goal: provide a description (in quotes), --file <path>, --template <name>, --resume <id>, --list, --list-templates, or --show <id>\n');
      process.exit(2);
    }
    try {
      goal = goalFromPrompt(prompt, { pattern: flags.pattern });
    } catch (err) {
      process.stderr.write(`goal prompt invalid: ${err.message}\n`);
      process.exit(2);
    }
  }
  // CLI default: mock-agents=true unless explicitly disabled.
  const mockAgents = flags.mockAgents === null ? true : flags.mockAgents;
  const onProgress = buildProgressEmitter(flags);
  let trace;
  try {
    trace = await runGoalLoop({
      goal,
      blackboardPath: flags.blackboard,
      maxWaitMs: flags.maxWaitMs,
      mockAgents,
      dryRun: flags.dryRun,
      onProgress,
      persistState: !flags.dryRun && flags.persistState,
      goalsDir: flags.goalsDir,
      resume: resumeMode,
      templateName: flags.template || null,
      templateContext: flags.template ? positional.slice(1).join(' ').trim() : null,
    });
  } catch (err) {
    if (err instanceof GoalValidationError) {
      process.stderr.write(`goal invalid: ${err.message}\n`);
      process.exit(2);
    }
    if (err instanceof BlackboardValidationError) {
      process.stderr.write(`blackboard error: ${err.message}\n`);
      process.exit(1);
    }
    process.stderr.write(`runtime error: ${err.stack || err.message || err}\n`);
    process.exit(1);
  }
  const tracePath = (!flags.dryRun && flags.traceDir) ? writeTrace(trace, flags.traceDir) : null;
  if (tracePath) trace.tracePath = path.relative(process.cwd(), tracePath);
  if (flags.json) emit(trace, true);
  else emit(renderTraceText(trace));
  if (flags.dryRun) return;
  process.exit(trace.ok ? 0 : 1);
}

function cmdStatus(_positional, flags) {
  const summary = blackboardSummary(flags.blackboard);
  if (flags.json) emit(summary, true);
  else emit(renderStatusText(summary));
}

function cmdDispatch(positional, flags) {
  const role = positional[1];
  const description = positional.slice(2).join(' ').trim();
  if (!role || !description) {
    process.stderr.write('openclaw dispatch: usage: openclaw dispatch <role> "<task description>"\n');
    process.exit(2);
  }
  let agent;
  try {
    agent = toSimpleAgentId(role, 'role');
  } catch (err) {
    process.stderr.write(`role invalid: ${err.message}\n`);
    process.exit(2);
  }
  let taskId;
  try {
    taskId = `dispatch-${toSimpleTaskId(description.slice(0, 40), 'task id')}-${Date.now().toString(36)}`;
  } catch (err) {
    process.stderr.write(`task description cannot be reduced to a task id: ${err.message}\n`);
    process.exit(2);
  }
  if (flags.dryRun) {
    const preview = {
      schema: 'openclaw-frontier.dispatch-preview.v1',
      dryRun: true,
      agent,
      taskId,
      summary: description.slice(0, 500),
    };
    if (flags.json) emit(preview, true);
    else emit(`would dispatch:\n  taskId: ${taskId}\n  agent: ${agent}\n  summary: ${preview.summary}`);
    return;
  }
  const ledger = createLedger({ ledgerPath: flags.blackboard });
  let record;
  try {
    record = ledger.claimTask({
      agent: 'orchestrator',
      taskId,
      summary: description.slice(0, 500),
    });
  } catch (err) {
    process.stderr.write(`dispatch failed: ${err.message}\n`);
    process.exit(1);
  }
  const result = {
    schema: 'openclaw-frontier.dispatch-receipt.v1',
    ok: true,
    agent,
    taskId,
    claimId: record.id,
    claimedAt: record.ts,
    blackboard: flags.blackboard,
    note: 'task-claim written. agent will pick the task off the ledger and respond with a result record.',
  };
  if (flags.json) emit(result, true);
  else emit(`dispatched ${taskId}\n  claim: ${record.id}\n  agent: ${agent}\n  blackboard: ${flags.blackboard}`);
}

function cmdRecap(_positional, flags) {
  const recap = recapBlackboard(flags.blackboard, {
    days: flags.days,
    includeCost: Boolean(flags.cost),
    goalsDir: flags.goalsDir,
  });
  if (flags.json) emit(recap, true);
  else emit(renderRecapText(recap));
}

// ---------- openclaw watch ----------

const ANSI = {
  reset: '\x1b[0m',
  dim: '\x1b[2m',
  bold: '\x1b[1m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  cyan: '\x1b[36m',
};

const KIND_COLOR = {
  'task-claim': 'cyan',
  'path-claim': 'yellow',
  'path-release': 'dim',
  'fact': 'blue',
  'decision': 'magenta',
  'result': 'green', // green for ok, red for not-ok (handled below)
};

function parseSince(raw) {
  if (!raw) return null;
  const s = String(raw).trim();
  if (!s) return null;
  // Relative form: 5m, 1h, 30s, 2d
  const rel = /^(\d+)\s*([smhd])$/i.exec(s);
  if (rel) {
    const n = Number(rel[1]);
    const unit = rel[2].toLowerCase();
    const factor = unit === 's' ? 1000 : unit === 'm' ? 60000 : unit === 'h' ? 3600000 : 86400000;
    return Date.now() - n * factor;
  }
  // ISO form
  const parsed = Date.parse(s);
  if (!Number.isFinite(parsed)) throw new Error(`--since: cannot parse "${raw}" (use ISO timestamp or 5m/1h/30s/2d)`);
  return parsed;
}

function formatTime(ts) {
  const d = new Date(ts);
  if (Number.isNaN(d.getTime())) return '??:??:??';
  return d.toISOString().slice(11, 19); // HH:MM:SS
}

function colorize(text, color, useColor) {
  if (!useColor || !color || !ANSI[color]) return text;
  return `${ANSI[color]}${text}${ANSI.reset}`;
}

function padRight(s, w) {
  s = String(s);
  if (s.length >= w) return s;
  return s + ' '.repeat(w - s.length);
}

function truncate(s, max) {
  s = String(s);
  if (s.length <= max) return s;
  return s.slice(0, max - 1) + '…';
}

function formatRecord(record, useColor) {
  const time = colorize(formatTime(record.ts), 'dim', useColor);
  const kindLabel = padRight(record.kind, 12);
  let color = KIND_COLOR[record.kind] || null;
  if (record.kind === 'result' && record.ok === false) color = 'red';
  const kind = colorize(kindLabel, color, useColor);
  const agent = colorize(padRight((record.agent || '-').slice(0, 12), 12), 'bold', useColor);
  const taskId = padRight((record.taskId || '-').slice(0, 24), 24);
  let detail = '';
  if (record.kind === 'task-claim') {
    detail = `"${truncate(record.summary || '', 60)}"`;
  } else if (record.kind === 'path-claim') {
    detail = `${record.path} (${record.mode || 'write'})`;
  } else if (record.kind === 'path-release') {
    detail = `${record.path}`;
  } else if (record.kind === 'fact') {
    detail = `${record.subject}`;
  } else if (record.kind === 'decision') {
    detail = `${record.decision} (${record.status || 'accepted'})`;
  } else if (record.kind === 'result') {
    const verdict = record.ok ? 'ok' : 'FAIL';
    const verdictColored = colorize(verdict, record.ok ? 'green' : 'red', useColor);
    const arts = record.artifacts && record.artifacts.length ? ` (artifact: ${record.artifacts[0]}${record.artifacts.length > 1 ? ` +${record.artifacts.length - 1}` : ''})` : '';
    detail = `${verdictColored} ${truncate(record.summary || '', 50)}${arts}`;
  }
  return `${time}  ${kind}  ${agent}  ${taskId}  ${detail}`;
}

function recordMatchesFilter(record, flags, sinceMs) {
  if (flags.filter && record.kind !== flags.filter) return false;
  if (flags.agent && record.agent !== flags.agent) return false;
  if (sinceMs != null) {
    const ts = Date.parse(record.ts);
    if (Number.isFinite(ts) && ts < sinceMs) return false;
  }
  return true;
}

function parseJsonlLines(text) {
  const out = [];
  const lines = text.split(/\r?\n/);
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    try {
      out.push(JSON.parse(trimmed));
    } catch (err) {
      // Skip malformed lines silently — the watcher should never block on bad
      // input the rest of the pipeline already validates.
    }
  }
  return out;
}

async function cmdWatch(_positional, flags) {
  const useColor = flags.color && process.stdout.isTTY !== false;
  let sinceMs;
  try {
    sinceMs = parseSince(flags.since);
  } catch (err) {
    process.stderr.write(`${err.message}\n`);
    process.exit(2);
  }
  const blackboardPath = flags.blackboard;

  // Print a small banner so the operator knows we're tailing.
  if (!flags.json) {
    process.stdout.write(`# openclaw watch: tailing ${blackboardPath}` +
      (flags.filter ? ` filter=${flags.filter}` : '') +
      (flags.agent ? ` agent=${flags.agent}` : '') +
      (flags.since ? ` since=${flags.since}` : '') +
      '\n');
  }

  // Tracking state. We poll the file size + emit any new bytes' worth of
  // records since the last position. This is the cheapest cross-platform
  // strategy and avoids fs.watch quirks on Windows.
  let lastSize = 0;
  let bufRemainder = '';
  let printedAny = false;
  let waitedFile = false;

  const printOne = (record) => {
    if (!recordMatchesFilter(record, flags, sinceMs)) return;
    if (flags.json) {
      process.stdout.write(JSON.stringify(record) + '\n');
    } else {
      process.stdout.write(formatRecord(record, useColor) + '\n');
    }
    printedAny = true;
  };

  // Initial pass: replay the current file (subject to --since), then keep
  // tailing.
  if (fs.existsSync(blackboardPath)) {
    const initial = fs.readFileSync(blackboardPath, 'utf8');
    lastSize = Buffer.byteLength(initial, 'utf8');
    for (const record of parseJsonlLines(initial)) printOne(record);
    if (!flags.json && !printedAny) process.stdout.write(`# (no matching records yet — waiting for activity)\n`);
  } else if (!flags.json) {
    process.stdout.write(`# (blackboard file not present yet — waiting)\n`);
    waitedFile = true;
  }

  // SIGINT: exit gracefully.
  let shuttingDown = false;
  process.on('SIGINT', () => {
    if (shuttingDown) process.exit(130);
    shuttingDown = true;
    if (!flags.json) process.stdout.write('\n# watch: interrupted\n');
    process.exit(0);
  });

  // Tail loop. Poll every 500ms; read only the new tail bytes since lastSize.
  // We do not use fs.watch because (a) it's unreliable on some Windows fs
  // backends and (b) we need ordered reads of append-only JSONL anyway.
  while (true) {
    let stat;
    try { stat = fs.statSync(blackboardPath); } catch (_) { stat = null; }
    if (!stat) {
      await sleep(500);
      continue;
    }
    if (waitedFile && stat.size > 0 && !flags.json) {
      process.stdout.write(`# (blackboard file appeared — tailing)\n`);
      waitedFile = false;
    }
    if (stat.size < lastSize) {
      // File got truncated/rotated. Re-seed from start.
      lastSize = 0;
      bufRemainder = '';
    }
    if (stat.size > lastSize) {
      const fd = fs.openSync(blackboardPath, 'r');
      try {
        const length = stat.size - lastSize;
        const buf = Buffer.alloc(length);
        fs.readSync(fd, buf, 0, length, lastSize);
        lastSize = stat.size;
        const text = bufRemainder + buf.toString('utf8');
        // Hold back any trailing partial line until we see the next newline.
        const lastNewline = text.lastIndexOf('\n');
        let complete;
        if (lastNewline === -1) {
          complete = '';
          bufRemainder = text;
        } else {
          complete = text.slice(0, lastNewline + 1);
          bufRemainder = text.slice(lastNewline + 1);
        }
        for (const record of parseJsonlLines(complete)) printOne(record);
      } finally {
        fs.closeSync(fd);
      }
    }
    await sleep(500);
  }
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

// ---------- openclaw ticket ----------

const TICKET_HELP = `openclaw ticket — agent ticketing FSM

Usage:
  openclaw ticket open "<title>" [--body <text>] [--by <agent>]
                                 [--assigned-to <agent>] [--priority p0|p1|p2]
                                 [--depends-on <id>] [--sla-hours <n>]
  openclaw ticket list           [--status <state>] [--assigned-to <agent>]
                                 [--priority <p>] [--blocked] [--since <when>]
  openclaw ticket show <id>
  openclaw ticket assign <id> --to <agent> --by <agent>
  openclaw ticket claim <id> --by <agent>
  openclaw ticket review <id> --by <agent> --reviewer <agent>
  openclaw ticket approve <id> --by <agent>
  openclaw ticket request-changes <id> --by <agent> --comment <text>
  openclaw ticket close <id> --by <agent> --resolution <text>
  openclaw ticket reopen <id> --by <agent> --reason <text>
  openclaw ticket add-dep <id> --depends-on <id> --by <agent>
  openclaw ticket remove-dep <id> --depends-on <id> --by <agent>
  openclaw ticket sla-breaches [--json]
  openclaw ticket recap [--days N] [--json]

Storage:
  Tickets live at release-gate/tickets.jsonl by default. Override via
  --tickets-path <path> or the OPENCLAW_TICKETS_PATH env var.

Authoring identity (--by) is required for every transition.

States: ${TICKET_STATES.join(' -> ')}; archived is terminal. The 'blocked'
flag is derived from open dependencies and shown by list/show.
`;

function ticketHelp() {
  process.stdout.write(TICKET_HELP);
}

function requireTicketFlag(flags, name, hint) {
  const val = flags[name];
  if (val == null || val === '') {
    process.stderr.write(`openclaw ticket: --${hint || name.replace(/[A-Z]/g, (c) => '-' + c.toLowerCase())} is required\n`);
    process.exit(2);
  }
  return val;
}

function renderTicketRow(t) {
  const blocked = t.blocked ? ' [BLOCKED]' : '';
  const assignee = t.assignedTo ? ` @${t.assignedTo}` : '';
  const sla = t.slaHours != null ? ` sla=${t.slaHours}h` : '';
  return `  ${t.id}  [${t.state}] ${t.priority}${assignee}${sla}${blocked}  ${t.title}`;
}

function renderTicketShow(t) {
  if (!t) return 'ticket not found';
  const lines = [];
  lines.push(`id: ${t.id}`);
  lines.push(`title: ${t.title}`);
  lines.push(`state: ${t.state}${t.blocked ? ' (BLOCKED)' : ''}`);
  lines.push(`priority: ${t.priority}`);
  lines.push(`assignedTo: ${t.assignedTo || '(unassigned)'}`);
  if (t.reviewer) lines.push(`reviewer: ${t.reviewer}`);
  lines.push(`createdAt: ${t.createdAt}`);
  lines.push(`createdBy: ${t.createdBy}`);
  lines.push(`updatedAt: ${t.updatedAt}`);
  if (t.slaHours != null) lines.push(`slaHours: ${t.slaHours}`);
  if (t.dependsOn && t.dependsOn.length) lines.push(`dependsOn: ${t.dependsOn.join(', ')}`);
  if (t.blockedBy && t.blockedBy.length) lines.push(`blockedBy: ${t.blockedBy.join(', ')}`);
  if (t.resolution) lines.push(`resolution: ${t.resolution}`);
  if (t.lastReviewComment) lines.push(`lastReviewComment: ${t.lastReviewComment}`);
  if (t.lastReopenReason) lines.push(`lastReopenReason: ${t.lastReopenReason}`);
  if (t.body) {
    lines.push('body:');
    for (const ln of String(t.body).split(/\r?\n/)) lines.push(`  ${ln}`);
  }
  lines.push(`history (${t.history.length} events):`);
  for (const h of t.history) lines.push(`  ${h.ts}  ${h.kind}  by ${h.by}`);
  return lines.join('\n');
}

function cmdTicket(positional, flags) {
  // positional[0] = 'ticket', positional[1] = action, positional[2+] = action args
  const action = positional[1];
  if (flags.help || action === 'help') {
    ticketHelp();
    return;
  }
  if (!action) {
    ticketHelp();
    process.exit(2);
  }
  const store = createTicketStore({ ticketsPath: flags.ticketsPath || undefined });

  try {
    switch (action) {
      case 'open': {
        const title = positional.slice(2).join(' ').trim();
        if (!title) {
          process.stderr.write('openclaw ticket open: provide a title in quotes\n');
          process.exit(2);
        }
        const by = flags.by || 'operator';
        const opts = { title, by };
        if (flags.body) opts.body = flags.body;
        if (flags.assignedTo) opts.assignedTo = flags.assignedTo;
        if (flags.priority) opts.priority = flags.priority;
        if (flags.dependsOn) opts.dependsOn = String(flags.dependsOn).split(',').map((s) => s.trim()).filter(Boolean);
        if (flags.slaHours != null && !Number.isNaN(flags.slaHours)) opts.slaHours = flags.slaHours;
        const evt = store.open(opts);
        const out = { ok: true, ticketId: evt.ticketId, eventId: evt.id, ts: evt.ts };
        if (flags.json) emit(out, true);
        else emit(`opened ticket ${evt.ticketId}`);
        return;
      }
      case 'list': {
        const filter = {};
        if (flags.status) filter.status = flags.status;
        if (flags.assignedTo) filter.assignedTo = flags.assignedTo;
        if (flags.priority) filter.priority = flags.priority;
        if (flags.blocked) filter.blockedBy = true;
        if (flags.since) filter.since = flags.since;
        const items = store.list(filter);
        if (flags.json) {
          emit({ ok: true, count: items.length, tickets: items }, true);
          return;
        }
        if (!items.length) { emit('no tickets match'); return; }
        const lines = [`tickets: ${items.length}`];
        for (const t of items) lines.push(renderTicketRow(t));
        emit(lines.join('\n'));
        return;
      }
      case 'show': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket show: missing <id>\n'); process.exit(2); }
        const t = store.get({ id });
        if (!t) {
          process.stderr.write(`ticket not found: ${id}\n`);
          process.exit(1);
        }
        if (flags.json) emit(t, true);
        else emit(renderTicketShow(t));
        return;
      }
      case 'assign': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket assign: missing <id>\n'); process.exit(2); }
        const to = requireTicketFlag(flags, 'to', 'to');
        const by = requireTicketFlag(flags, 'by', 'by');
        const evt = store.assign({ id, to, by });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`assigned ${id} to ${to}`);
        return;
      }
      case 'claim': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket claim: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const evt = store.claim({ id, by });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`claimed ${id} by ${by}`);
        return;
      }
      case 'review': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket review: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const reviewer = requireTicketFlag(flags, 'reviewer', 'reviewer');
        const evt = store.requestReview({ id, by, reviewer });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`review requested for ${id} (reviewer: ${reviewer})`);
        return;
      }
      case 'approve': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket approve: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const evt = store.approveReview({ id, by });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`approved ${id}`);
        return;
      }
      case 'request-changes': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket request-changes: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const comment = requireTicketFlag(flags, 'comment', 'comment');
        const evt = store.requestChanges({ id, by, comment });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`changes requested on ${id}`);
        return;
      }
      case 'close': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket close: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const resolution = requireTicketFlag(flags, 'resolution', 'resolution');
        const evt = store.close({ id, by, resolution });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`closed ${id}: ${resolution}`);
        return;
      }
      case 'reopen': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket reopen: missing <id>\n'); process.exit(2); }
        const by = requireTicketFlag(flags, 'by', 'by');
        const reason = requireTicketFlag(flags, 'reason', 'reason');
        const evt = store.reopen({ id, by, reason });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`reopened ${id}`);
        return;
      }
      case 'add-dep': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket add-dep: missing <id>\n'); process.exit(2); }
        const dependsOn = requireTicketFlag(flags, 'dependsOn', 'depends-on');
        const by = requireTicketFlag(flags, 'by', 'by');
        const evt = store.addDependency({ id, dependsOn, by });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`added dependency ${id} -> ${dependsOn}`);
        return;
      }
      case 'remove-dep': {
        const id = positional[2];
        if (!id) { process.stderr.write('openclaw ticket remove-dep: missing <id>\n'); process.exit(2); }
        const dependsOn = requireTicketFlag(flags, 'dependsOn', 'depends-on');
        const by = requireTicketFlag(flags, 'by', 'by');
        const evt = store.removeDependency({ id, dependsOn, by });
        if (flags.json) emit({ ok: true, eventId: evt.id }, true);
        else emit(`removed dependency ${id} -> ${dependsOn}`);
        return;
      }
      case 'sla-breaches': {
        const breaches = store.checkSlaBreaches();
        if (flags.json) {
          emit({ ok: true, count: breaches.length, breaches }, true);
          return;
        }
        if (!breaches.length) { emit('no SLA breaches'); return; }
        const lines = [`SLA breaches: ${breaches.length}`];
        for (const b of breaches) {
          lines.push(`  ${b.id}  [${b.state}] ${b.priority}  sla=${b.slaHours}h elapsed=${b.elapsedHours}h  ${b.title}`);
        }
        emit(lines.join('\n'));
        return;
      }
      case 'recap': {
        const days = flags.days || 7;
        const recap = store.recap({ days });
        if (flags.json) emit(recap, true);
        else {
          const lines = [];
          lines.push(`tickets: ${recap.ticketsPath}`);
          lines.push(`window: ${recap.windowDays} day(s)  as-of ${recap.now}`);
          lines.push(`total: ${recap.total}`);
          for (const s of TICKET_STATES) lines.push(`  ${s}: ${recap.counts[s] || 0}`);
          lines.push(`SLA breaches: ${recap.slaBreachCount}`);
          for (const b of recap.slaBreaches) {
            lines.push(`  - ${b.id} elapsed=${b.elapsedHours}h sla=${b.slaHours}h`);
          }
          lines.push(`recently updated: ${recap.recentlyUpdated.length}`);
          for (const r of recap.recentlyUpdated) {
            lines.push(`  - ${r.updatedAt}  ${r.id}  [${r.state}]  ${r.title}`);
          }
          emit(lines.join('\n'));
        }
        return;
      }
      default:
        process.stderr.write(`unknown ticket action: ${action}\n`);
        ticketHelp();
        process.exit(2);
    }
  } catch (err) {
    if (err instanceof TicketStateError) {
      process.stderr.write(`ticket state error: ${err.message}\n`);
      process.exit(1);
    }
    if (err instanceof TicketValidationError) {
      process.stderr.write(`ticket validation error: ${err.message}\n`);
      process.exit(2);
    }
    throw err;
  }
}

async function main() {
  if (process.argv.length <= 2) { help(); process.exit(2); }
  const { flags, positional } = parseGlobal(process.argv);
  const sub = positional[0];
  // Sub-help: "openclaw ticket --help" should print the ticket help, not the
  // global help. We let the subcommand decide.
  if (sub === 'ticket' && flags.help) { return cmdTicket(positional, flags); }
  if (flags.help || positional[0] === 'help') { help(); return; }
  switch (sub) {
    case 'goal': return cmdGoal(positional, flags);
    case 'status': return cmdStatus(positional, flags);
    case 'dispatch': return cmdDispatch(positional, flags);
    case 'recap': return cmdRecap(positional, flags);
    case 'watch': return cmdWatch(positional, flags);
    case 'ticket': return cmdTicket(positional, flags);
    case undefined: help(); process.exit(2); return;
    default:
      process.stderr.write(`unknown subcommand: ${sub}\n`);
      help();
      process.exit(2);
  }
}

main().catch((err) => {
  process.stderr.write(`openclaw: ${err.stack || err.message || err}\n`);
  process.exit(1);
});
