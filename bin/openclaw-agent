    parseCanCannot,
    enforceHardRules,
    extractTokens,
    findPendingClaims,
    buildSystemPrompt,
    signRecord,
  };
} else {
  main().catch((err) => {
    process.stderr.write(`openclaw-agent: ${err.stack || err.message || err}\n`);
    process.exit(1);
  });
}
