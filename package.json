{
  "name": "@openclaw/frontier-stack",
  "version": "0.8.1",
  "description": "Production-ready, drop-in interoperable agent skills + hooks + orchestration harness for Claude Code, Codex, Cursor, OpenCode, and any agent that supports the Agent Skills specification. Ships 87 skills (47 marketing + creative as Modern Skills, 37 engineering workflow, 3 operator), 11 role contracts, an engineer CLI (openclaw) with goal templating + state persistence + ticketing v2 (templates, multi-assignee, watchers, SLA pause, goal binding), a live agent runner daemon (openclaw-agent), 4 coordination patterns plus subagent fan-out, goal v3 (failure-recovery policies, sub-goals, --gantt, --diff, cancellation tokens), 5 autonomous loops, a Rust core workspace (envelope, blackboard, taskflow crates with canonical-JSON parity), N-API FFI binding with pure-JS fallback, Hermes-port system layer (openclaw-cron, openclaw doctor, openclaw-webhook, supply-chain advisory, gateway-style event-hook lifecycle), a graded release-gate (mutation-testing scorecard, live-model skill eval, triggering-accuracy scorer, weighted composite letter grade), and a multi-host agent integration installer that bridges OFS skills + bin into operator-defined agent hosts. Plus the OpenClaw Frontier Stack production core: signed coordination, durable task ownership, ticketing FSM, memory, observability, and fail-closed release gates.",
  "license": "MIT",
  "type": "commonjs",
  "private": false,
  "bin": {
    "openclaw": "./bin/openclaw",
    "openclaw-agent": "./bin/openclaw-agent",
    "openclaw-cron": "./bin/openclaw-cron",
    "openclaw-webhook": "./bin/openclaw-webhook"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "verify": "node scripts/verify-package.js",
    "verify:history": "node scripts/verify-git-history-clean.js",
    "verify:owner-approval": "node release-gate/scripts/verify-owner-upload-approval.js",
    "verify:skills": "bash scripts/validate-skills.sh",
    "test": "node scripts/verify-package.js",
    "release:pack": "node scripts/package-release.js",
    "install:check": "node scripts/check-environment.js",
    "prepare": "git config core.hooksPath .githooks || true",
    "install-hooks": "git config core.hooksPath .githooks",
    "verify:package": "node scripts/verify-package.js",
    "verify:approval": "node release-gate/scripts/verify-owner-upload-approval.js",
    "verify:public-surface": "node release-gate/scripts/verify-public-surface-harness.js",
    "verify:github-readback": "node release-gate/scripts/verify-github-public-readback.js",
    "smoke": "node scripts/run-demos.js",
    "eval:dry": "node scripts/run-skill-evals.js",
    "eval:live": "node scripts/run-skill-evals.js --live",
    "verify:supply-chain": "node release-gate/scripts/verify-supply-chain-advisory.js",
    "test:supply-chain": "node release-gate/scripts/test-supply-chain-advisory.js",
    "test:cron": "node cron/test/scheduler.test.js",
    "test:webhook": "node webhook/test/webhook.test.js",
    "test:agent-host-integration": "node integration/agent-host/test/install.test.js",
    "install:agent-host": "node integration/agent-host/install.js",
    "uninstall:agent-host": "node integration/agent-host/install.js --uninstall",
    "grade": "node scripts/grade.js",
    "grade:dry": "node scripts/grade.js --skip-mutation",
    "grade:tier-3": "node scripts/grade.js --tier-3"
  },
  "files": [
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/",
    ".opencode/",
    "agents/",
    ".github/workflows/verify-package.yml",
    ".gitignore",
    ".githooks/",
    ".npmignore",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "bin/",
    "crates/",
    "cron/",
    "docs/",
    "examples/",
    "hooks/",
    "integration/",
    "lib/",
    "release-gate/checklist.md",
    "release-gate/lib/",
    "release-gate/release-notes/",
    "release-gate/reviewer-decision.template.yaml",
    "release-gate/reviewer-decision-schema.md",
    "release-gate/scorecards/",
    "release-gate/scripts/",
    "scripts/",
    "skills/",
    "src/",
    "templates/",
    "test/",
    "webhook/",
    "STATUS.md",
    "docs/security/"
  ],
  "keywords": [
    "openclaw",
    "multi-agent",
    "coding-swarm",
    "orchestration",
    "release-gates",
    "production-ready",
    "drop-in",
    "agent-orchestration",
    "marketing-skills",
    "ecommerce",
    "claude-code-plugin",
    "codex-plugin",
    "cursor-plugin",
    "opencode-plugin",
    "agent-skills-spec",
    "interoperable"
  ],
  "optionalDependencies": {
    "nats": "^2.29.3"
  }
}
